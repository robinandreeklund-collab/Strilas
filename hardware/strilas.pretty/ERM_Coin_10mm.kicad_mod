(footprint "ERM_Coin_10mm" (version 20221018) (generator strilas)
  (layer "F.Cu")
  (descr "STRILAS ERM coin-vibrationsmotor Ø10x3mm (3V). 2 SMD-lödpads (pad1=+ , pad2=-) under en Ø10mm motorkropp (limmas/dubbelhäftas). pad1=+ -> 3V3, pad2=- -> VIB (TPIC low-side). Vanlig coin-typ (1027/B1034 m.fl.).")
  (tags "erm coin vibration motor haptic 10mm 3v")
  (attr smd)
  (fp_text reference "REF**" (at 0 -6) (layer "F.SilkS") (effects (font (size 0.8 0.8) (thickness 0.12))))
  (fp_text value "ERM_Coin_10mm" (at 0 6) (layer "F.Fab") (effects (font (size 0.7 0.7) (thickness 0.1))))
  (fp_text user "${REFERENCE}" (at 0 0) (layer "F.Fab") (effects (font (size 0.7 0.7) (thickness 0.1))))
  (fp_circle (center 0 0) (end 5 0) (stroke (width 0.12) (type solid)) (fill none) (layer "F.SilkS"))
  (fp_circle (center 0 0) (end 5 0) (stroke (width 0.1) (type solid)) (fill none) (layer "F.Fab"))
  (fp_circle (center 0 0) (end 5.25 0) (stroke (width 0.05) (type solid)) (fill none) (layer "F.CrtYd"))
  (fp_text user "+" (at -3.2 -2.4) (layer "F.SilkS") (effects (font (size 1 1) (thickness 0.15))))
  (pad "1" smd roundrect (at -2.7 0) (size 2.4 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.25))
  (pad "2" smd roundrect (at 2.7 0) (size 2.4 3.2) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.25))
  (model "${KIPRJMOD}/erm-coin-3d.step"
    (offset (xyz 0 0 0))
    (scale (xyz 1 1 1))
    (rotate (xyz 0 0 0))
  )
)
