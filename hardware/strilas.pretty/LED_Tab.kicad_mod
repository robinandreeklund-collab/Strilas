(footprint "LED_Tab" (version 20221018) (generator strilas)
  (layer "F.Cu")
  (descr "STRILAS LED-tab sockel: 2-håls fot (1x2 2.54mm, drop-in mot PinHeader_1x02_Vertical) för en LODRÄT OSLON-tab-microPCB. Kunden löder en right-angle 90°-stiftlist i tabbens fot → tabben står lodrät i dessa hål. pad1=A(anod) pad2=K(katod). 3D = stående tab, OSLON strålar +X (silk-pil).")
  (tags "led tab oslon sfh4715as 860nm right-angle constellation")
  (attr through_hole)
  (fp_text reference "REF**" (at -2 1.27 90) (layer "F.SilkS") (effects (font (size 0.8 0.8) (thickness 0.12))))
  (fp_text value "LED_Tab" (at 0 5.3) (layer "F.Fab") (effects (font (size 0.7 0.7) (thickness 0.1))))
  (fp_text user "${REFERENCE}" (at 2.4 1.27 90) (layer "F.Fab") (effects (font (size 0.7 0.7) (thickness 0.1))))
  (fp_line (start -1 -2) (end 1 -2) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
  (fp_line (start -1 4.5) (end 1 4.5) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
  (fp_line (start -1 -2) (end -1 4.5) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
  (fp_line (start 1 -2) (end 1 4.5) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
  (fp_line (start 1 1.27) (end 2.9 1.27) (stroke (width 0.15) (type solid)) (layer "F.SilkS"))
  (fp_line (start 2.9 1.27) (end 2.2 0.75) (stroke (width 0.15) (type solid)) (layer "F.SilkS"))
  (fp_line (start 2.9 1.27) (end 2.2 1.79) (stroke (width 0.15) (type solid)) (layer "F.SilkS"))
  (fp_line (start -1 -2) (end 1 -2) (stroke (width 0.1) (type solid)) (layer "F.Fab"))
  (fp_line (start -1 4.5) (end 1 4.5) (stroke (width 0.1) (type solid)) (layer "F.Fab"))
  (fp_line (start -1 -2) (end -1 4.5) (stroke (width 0.1) (type solid)) (layer "F.Fab"))
  (fp_line (start 1 -2) (end 1 4.5) (stroke (width 0.1) (type solid)) (layer "F.Fab"))
  (fp_poly (pts (xy -1 0) (xy -1.5 -0.5) (xy -1.5 0.5)) (stroke (width 0.1) (type solid)) (fill solid) (layer "F.Fab"))
  (fp_rect (start -1.3 -2.3) (end 3.3 4.8) (stroke (width 0.05) (type solid)) (fill none) (layer "F.CrtYd"))
  (pad "1" thru_hole rect (at 0 0) (size 1.7 1.7) (drill 1) (layers "*.Cu" "*.Mask"))
  (pad "2" thru_hole oval (at 0 2.54) (size 1.7 1.7) (drill 1) (layers "*.Cu" "*.Mask"))
  (model "${KIPRJMOD}/led-tab-3d.step"
    (offset (xyz 0 0 0)) (scale (xyz 1 1 1)) (rotate (xyz 0 0 0)))
)
